		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ  
	МЕСЯЦ(РасходРасходы.Ссылка.Дата) КАК Месяц,
	ГОД(РасходРасходы.Ссылка.Дата) КАК Год,
	РасходРасходы.СтатьяРасходаИмущество КАК СтатьяРасходов,
	СУММА(РасходРасходы.Сумма) КАК Сумма,
	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РасходРасходы.Ссылка) КАК Количество,
	ВЫБОР
		КОГДА КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РасходРасходы.Ссылка) = 0
			ТОГДА 0
		ИНАЧЕ СУММА(РасходРасходы.Сумма) / КОЛИЧЕСТВО(РАЗЛИЧНЫЕ РасходРасходы.Ссылка)
	КОНЕЦ КАК СреднийЧек
ИЗ
	Документ.Расход.Расходы КАК РасходРасходы
ГДЕ
	НЕ РасходРасходы.Ссылка.ЭтоШаблон
	И РасходРасходы.Ссылка.Проведен
	И НЕ РасходРасходы.Ссылка.ПометкаУдаления

СГРУППИРОВАТЬ ПО
	РасходРасходы.СтатьяРасходаИмущество,
	МЕСЯЦ(РасходРасходы.Ссылка.Дата),
	ГОД(РасходРасходы.Ссылка.Дата)

УПОРЯДОЧИТЬ ПО
	Сумма УБЫВ</query>
