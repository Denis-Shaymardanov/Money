Функция ЗагрузитьДанныеЧекаИзНалоговой() Экспорт
	
	СтруктураОтвета = Новый Структура("Ответ, ОписаниеОшибки", Неопределено, "");	
	
	ПараметрыПолученияЧека = ПолучитьПараметрыПолученияЧека();
	ДанныеЧекаИзНалоговой = ПолучитьДанныеЧекаИзНалоговой(ПараметрыПолученияЧека); 
	
	Если ЗначениеЗаполнено(ДанныеЧекаИзНалоговой.ОписаниеОшибки) Тогда
		ЗаполнитьЗначенияСвойств(СтруктураОтвета, ДанныеЧекаИзНалоговой);
		Возврат СтруктураОтвета;
	КонецЕсли;	                
	
	ОбработатьДанныеЧекаИЗаполнитьНоменклатуру(ДанныеЧекаИзНалоговой.Ответ);
	
	//Если все ОК - установим признак, что чек загружен, а также запишем документ
	Если НЕ ЗначениеЗаполнено(СтруктураОтвета.ОписаниеОшибки) Тогда
		ЭтотОбъект.УчетТоваров_ЗагруженИзНалоговой = Истина;
		ЭтотОбъект.Записать(РежимЗаписиДокумента.Проведение);
	КонецЕсли;
	
	Возврат СтруктураОтвета;
	
КонецФункции 

